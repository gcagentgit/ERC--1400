{
  "name": "erc-1400-security-token",
  "version": "1.0.0",
  "description": "ERC-1400 Security Token Implementation with comprehensive deployment options",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network sepolia",
    "deploy:goerli": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network goerli",
    "deploy:mumbai": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network mumbai",
    "deploy:mainnet": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network mainnet",
    "deploy:polygon": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network polygon",
    "deploy:arbitrum": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network arbitrum",
    "deploy:optimism": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network optimism",
    "deploy:base": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network base",
    "deploy:avalanche": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network avalanche",
    "deploy:bsc": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network bsc",
    "deploy:local": "hardhat ignition deploy ignition/modules/ERC1400Module.ts --network localhost",
    "verify": "hardhat verify",
    "slither": "slither .",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "format": "prettier --write 'contracts/**/*.sol' 'test/**/*.ts' 'ignition/**/*.ts'",
    "node": "hardhat node",
    "clean": "hardhat clean && rm -rf cache artifacts typechain-types"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "dotenv": "^16.3.0",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.1.0",
    "prettier-plugin-solidity": "^1.2.0",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0"
  },
  "keywords": [
    "ethereum",
    "erc-1400",
    "security-token",
    "blockchain",
    "solidity",
    "smart-contracts"
  ],
  "author": "",
  "license": "MIT"
}
